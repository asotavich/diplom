# =============================================================================
# FEAnalyzer — production environment variables (TEMPLATE)
# -----------------------------------------------------------------------------
# This file is a TEMPLATE. Copy it to `.env.production` on the production host
# and replace every CHANGE_ME_* placeholder with a real secret. The real
# `.env.production` is git-ignored and must NEVER be committed.
#
# On the VPS:
#   1. cp .env.production.example .env.production
#   2. Replace every CHANGE_ME_* value with a real secret.
#   3. Replace every `yourdomain.com` reference with your real domain.
#   4. Run `docker compose --env-file .env.production up -d --build`.
#
# Generate a Django secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# =============================================================================

# ---- Django ---------------------------------------------------------------
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_64
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---- PostgreSQL -----------------------------------------------------------
POSTGRES_DB=feanalyzer
POSTGRES_USER=feanalyzer_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis / Celery -------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- CORS (front-end origins) ---------------------------------------------
# Comma-separated list of HTTPS origins the React SPA will be served from.
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---- JWT lifetimes (minutes / days) ---------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
