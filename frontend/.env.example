# =============================================================================
# FEAnalyzer frontend — local dev config
# Copy to `.env.local` and tweak. Vite only exposes VITE_* variables to the
# browser, so keep secrets out of here.
# =============================================================================

# Base URL of the backend API. In Docker Compose this stays as /api because
# nginx proxies both the SPA and the API on the same origin. In bare `npm run
# dev` mode Vite's dev proxy (see vite.config.js) rewrites /api to Django on :8000.
VITE_API_BASE_URL=/api

# Only used by `npm run dev`: where the dev proxy should forward /api to.
# Set to the address of your running Django process.
VITE_DEV_API_PROXY=http://localhost:8000
